# =============================================================================
# Atlas — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
# Never commit `.env.local` — it is gitignored by default.
# For Vercel: Project Settings → Environment Variables に同名で登録してください。
# =============================================================================

# -----------------------------------------------------------------------------
# 【必須】本番（Vercel Production）へ登録
# -----------------------------------------------------------------------------

# OpenAI API key（サーバー専用。ブラウザへ露出しないこと）
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Clerk Authentication
# https://dashboard.clerk.com/ → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Auth page paths（アプリ内ルートと一致させる）
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# 公開サイトURL（SEO / OGP / sitemap / Stripe 戻り先）
# 初回デプロイ前は仮で可。公開URL確定後に正式URLへ変更して再デプロイ。
# 例: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=
# Stripe 等で APP_URL を参照する場合（未設定時は SITE_URL / VERCEL_URL を利用）
NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# 【推奨】課金・オーナー・連携を使う場合
# -----------------------------------------------------------------------------

# ATLAS Owner Console（カンマ区切りメール）
# ATLAS_OWNER_EMAILS=
# ATLAS_BETA_USER_EMAILS=

# Stripe Billing（任意）
# https://dashboard.stripe.com/
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_LIGHT=
# STRIPE_PRICE_STANDARD=
# STRIPE_PRICE_PREMIUM=
# Webhook endpoint 例: https://your-app.vercel.app/api/billing/webhook

# Google OAuth（任意）
# https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# 本番リダイレクト例:
#   https://your-app.vercel.app/api/external-services/google/oauth/callback
#   https://your-app.vercel.app/api/integrations/oauth/google-drive/callback
# GOOGLE_REDIRECT_URI=

# X (Twitter) OAuth（任意）
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI=

# Supabase（任意 — DB 永続化を使う場合）
# https://supabase.com/dashboard
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_ATLAS_PROJECT_STORAGE=supabase

# -----------------------------------------------------------------------------
# 【ローカルのみ】開発・デバッグ（本番では false / 未設定推奨）
# -----------------------------------------------------------------------------

# ATLAS_MOCK_LLM=true
# ATLAS_DEBUG=true
# NEXT_PUBLIC_ATLAS_DEBUG=false
# ATLAS_DEBUG_VERBOSE=true
# ATLAS_CORE_TEST=true

# API Usage Budgets（オーナー画面用・任意）
# ATLAS_API_BUDGET_OPENAI_USD=500
# ATLAS_API_BUDGET_GOOGLE_USD=200
# ATLAS_API_BUDGET_STRIPE_USD=150
# ATLAS_API_BUDGET_X_USD=100
# ATLAS_API_BUDGET_WORDPRESS_USD=50
