# =============================================================================
# Atlas — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
# Never commit `.env.local` — it is gitignored by default.
# For Vercel: Project Settings → Environment Variables に同名で登録してください。
# =============================================================================

# -----------------------------------------------------------------------------
# 【必須】本番（Vercel Production）へ登録
# -----------------------------------------------------------------------------

# OpenAI API key（サーバー専用。ブラウザへ露出しないこと）
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Clerk Authentication
# https://dashboard.clerk.com/ → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Auth page paths（アプリ内ルートと一致させる）
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# 公開サイトURL（SEO / OGP / sitemap / Stripe 戻り先）
# 初回デプロイ前は仮で可。公開URL確定後に正式URLへ変更して再デプロイ。
# 例: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=
# Stripe 等で APP_URL を参照する場合（未設定時は SITE_URL / VERCEL_URL を利用）
NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# 【推奨】課金・オーナー・連携を使う場合
# -----------------------------------------------------------------------------

# ATLAS Owner Console（カンマ区切りメール）
# ATLAS_OWNER_EMAILS=
# ATLAS_BETA_USER_EMAILS=

# Stripe Billing（テストモードで決済・Webhook・Customer Portal を使う場合）
# https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=                 # サーバー専用 Secret Key（sk_test_...）。クライアントへ出さない
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # 公開可能キー（pk_test_...）
# STRIPE_WEBHOOK_SECRET=             # Webhook 署名検証用（whsec_...）。必須
# STRIPE_PRICE_LIGHT=                # Light プランの Price ID（price_...）
# STRIPE_PRICE_STANDARD=             # Standard プランの Price ID
# STRIPE_PRICE_PREMIUM=              # Premium プランの Price ID
# Webhook endpoint 例: https://your-app.vercel.app/api/billing/webhook
# ローカル転送例: stripe listen --forward-to localhost:3000/api/billing/webhook
# Customer Portal: Dashboard → Settings → Billing → Customer portal（テストモードで有効化）

# Google OAuth（任意）
# https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# 本番リダイレクト例:
#   https://atlas-two-blush-43.vercel.app/api/external-services/google/oauth/callback
#   https://atlas-two-blush-43.vercel.app/api/integrations/oauth/google-drive/callback
# GOOGLE_REDIRECT_URI=https://atlas-two-blush-43.vercel.app/api/external-services/google/oauth/callback
# Gmail / Calendar 書き込みには再同意が必要です。
# 有効化API: Gmail API / Google Calendar API / Google Drive API
# OAuth 同意画面のスコープ例: gmail.modify, gmail.send, gmail.compose, calendar.events, drive

# X (Twitter) OAuth（任意）
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI=

# Dropbox OAuth（任意）
# https://www.dropbox.com/developers/apps
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=
# 本番リダイレクト例:
#   https://atlas-two-blush-43.vercel.app/api/external-services/dropbox/oauth/callback
# DROPBOX_REDIRECT_URI=https://atlas-two-blush-43.vercel.app/api/external-services/dropbox/oauth/callback
# スコープ例: account_info.read files.content.read files.content.write sharing.write sharing.read

# LINE Messaging API（任意 — LINE通知）
# https://developers.line.biz/console/
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
# LINE_BOT_BASIC_ID=                  # 例: @atlasxxxxx（友だち追加案内用）
# Webhook URL 例: https://atlas-two-blush-43.vercel.app/api/line/webhook
# NEXT_PUBLIC_APP_URL=https://atlas-two-blush-43.vercel.app

# Supabase（任意 — DB 永続化を使う場合）
# https://supabase.com/dashboard
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_ATLAS_PROJECT_STORAGE=supabase

# -----------------------------------------------------------------------------
# 【ローカルのみ】開発・デバッグ（本番では false / 未設定推奨）
# -----------------------------------------------------------------------------

# ATLAS_MOCK_LLM=true
# ATLAS_DEBUG=true
# NEXT_PUBLIC_ATLAS_DEBUG=false
# ATLAS_DEBUG_VERBOSE=true
# ATLAS_CORE_TEST=true

# API Usage Budgets（オーナー画面用・任意）
# ATLAS_API_BUDGET_OPENAI_USD=500
# ATLAS_API_BUDGET_GOOGLE_USD=200
# ATLAS_API_BUDGET_STRIPE_USD=150
# ATLAS_API_BUDGET_X_USD=100
# ATLAS_API_BUDGET_WORDPRESS_USD=50
