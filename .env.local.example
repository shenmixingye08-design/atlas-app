# =============================================================================
# Atlas — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
# Never commit `.env.local` — it is gitignored by default.
# For Vercel: Project Settings → Environment Variables に同名で登録してください。
# =============================================================================

# -----------------------------------------------------------------------------
# 【必須】本番（Vercel Production）へ登録
# -----------------------------------------------------------------------------

# OpenAI API key（サーバー専用。ブラウザへ露出しないこと）
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Clerk Authentication
# https://dashboard.clerk.com/ → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# 本番は pk_live_ / sk_live_ を使用（pk_test_ / sk_test_ 禁止）

# Auth page paths（アプリ内ルートと一致させる）
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Clerk Webhook（ログイン/ログアウト監査・本番必須）
# Dashboard → Webhooks → endpoint:
#   https://your-app.vercel.app/api/webhooks/clerk
# Events: session.created, session.ended, session.removed
CLERK_WEBHOOK_SECRET=

# 公開サイトURL（SEO / OGP / sitemap / Stripe 戻り先）
# 例: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_URL=

# ATLAS Owner Console（本番必須・カンマ区切りメール）
ATLAS_OWNER_EMAILS=

# 特定商取引法表記（/legal・本番公開前に必須）
# ATLAS_OPERATOR_BUSINESS_NAME=ATLAS
# ATLAS_OPERATOR_REPRESENTATIVE_NAME=
# ATLAS_OPERATOR_ADDRESS=
# ATLAS_OPERATOR_CONTACT_EMAIL=support@example.com

# Vercel Cron / 自動化 tick 認証（本番必須）
# Vercel が Cron 実行時に Authorization: Bearer <CRON_SECRET> を付与します
CRON_SECRET=

# OAuth CSRF state 署名（本番は OAUTH_STATE_SECRET 推奨。未設定時は CLERK_SECRET_KEY）
# OAUTH_STATE_SECRET=

# -----------------------------------------------------------------------------
# 【必須・課金を公開する場合】Stripe 本番（Live Mode）
# -----------------------------------------------------------------------------
# テストキー（sk_test_ / pk_test_）のまま Production 公開しないこと
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LIGHT=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
#
# --- Stripe Dashboard 設定チェックリスト ---
# 1) Products → Light/Standard/Premium の Price ID を上に登録（Live Mode）
# 2) Developers → Webhooks → Add endpoint:
#      URL: https://your-app.vercel.app/api/billing/webhook
#      （互換: /api/stripe/webhook も同一ハンドラ）
#      購読イベント:
#        checkout.session.completed
#        customer.subscription.created
#        customer.subscription.updated
#        customer.subscription.deleted
#        invoice.paid
#        invoice.payment_succeeded
#        invoice.payment_failed
#        charge.refunded
#      Signing secret → STRIPE_WEBHOOK_SECRET
# 3) Settings → Billing → Customer portal を有効化
#      （解約・支払い方法更新はポータル経由。アプリ内モックは本番無効）
# 4) Trial は Price / Dashboard 側で設定（アプリは trialing を有料扱いとして同期）
# 5) Checkout success URL: /billing/success  cancel: /billing/cancel
# Webhook: https://your-app.vercel.app/api/billing/webhook

# -----------------------------------------------------------------------------
# 【推奨】ベータ・外部連携
# -----------------------------------------------------------------------------

# ATLAS_BETA_USER_EMAILS=

# Google OAuth（Gmail / Calendar / Drive 共通・本番必須）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# 本番必須（Host 自動解決は禁止）:
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/external-services/google/oauth/callback
# （互換エイリアス: GOOGLE_ACCOUNT_REDIRECT_URI）
#
# --- Google Cloud Console チェックリスト ---
# 1) APIs & Services → Enable:
#      Gmail API / Google Calendar API / Google Drive API
# 2) Credentials → OAuth 2.0 Client (Web application)
#      Authorized redirect URIs:
#        https://your-app.vercel.app/api/external-services/google/oauth/callback
#      （ローカル例）http://localhost:3000/api/external-services/google/oauth/callback
# 3) OAuth consent screen:
#      External + 本番公開 / テストなら Test users 登録
#      Scopes: openid email profile
#        https://www.googleapis.com/auth/gmail.modify
#        https://www.googleapis.com/auth/gmail.send
#        https://www.googleapis.com/auth/gmail.compose
#        https://www.googleapis.com/auth/calendar.events
#        https://www.googleapis.com/auth/drive
# 4) refresh_token 永続化のため Supabase（下記）を本番で設定推奨
#      （トークンは Clerk overflow 時に strip される）

# X (Twitter) OAuth（任意）
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI=

# Dropbox OAuth（任意）
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=
# DROPBOX_REDIRECT_URI=

# LINE Messaging API（通知・Webhook）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
# LINE_BOT_BASIC_ID=
#
# --- LINE Developers 設定チェックリスト ---
# 1) Messaging API チャネルを作成（LINE Login は未使用）
# 2) Channel access token (long-lived) → LINE_CHANNEL_ACCESS_TOKEN
# 3) Channel secret → LINE_CHANNEL_SECRET
# 4) Basic ID（@xxx）→ LINE_BOT_BASIC_ID（設定画面の友だち追加案内用・任意）
# 5) Webhook URL:
#      https://your-app.vercel.app/api/line/webhook
#      （NEXT_PUBLIC_APP_URL と同じ本番ドメイン）
# 6) Use webhook = Enabled
# 7) 連携コード・通知先の永続化には Supabase（下記）を本番推奨
#
# 未設定時: LINE連携は無効（configured=false）。アプリ全体は起動継続。

# Supabase（推奨 — OAuth トークン / LINE連携インデックス含む永続化）
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # サーバー専用。atlas_user_state 書き込みに必須（RLS バイパス）
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_ATLAS_PROJECT_STORAGE=supabase

# -----------------------------------------------------------------------------
# 【ローカルのみ】開発・デバッグ（本番では false / 未設定推奨）
# -----------------------------------------------------------------------------

# ATLAS_MOCK_LLM=true
# ATLAS_DEBUG=true
# NEXT_PUBLIC_ATLAS_DEBUG=false
# ATLAS_DEBUG_VERBOSE=true
# ATLAS_CORE_TEST=true

# API Usage Budgets（オーナー画面用・任意）
# ATLAS_API_BUDGET_OPENAI_USD=500
# ATLAS_API_BUDGET_GOOGLE_USD=200
# ATLAS_API_BUDGET_STRIPE_USD=150
# ATLAS_API_BUDGET_X_USD=100
# ATLAS_API_BUDGET_WORDPRESS_USD=50
